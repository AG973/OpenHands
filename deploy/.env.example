# CODEIT Production Environment Configuration
# Copy to .env and customize for your server

# ─── LLM Settings ───────────────────────────────────────────
LLM_MODEL=ollama/deepseek-r1:8b
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=ollama
LLM_NATIVE_TOOL_CALLING=false

# ─── CODEIT Auth ────────────────────────────────────────────
CODEIT_ADMIN_USER=admin
CODEIT_ADMIN_PASS=codeit
# Change this in production!

# ─── CODEIT Data ────────────────────────────────────────────
CODEIT_DATA_DIR=/root/.codeit
CODEIT_UPLOAD_DIR=/root/.codeit/uploads

# ─── Server ─────────────────────────────────────────────────
WORKSPACE_BASE=/root/workspace
SERVE_FRONTEND=false
